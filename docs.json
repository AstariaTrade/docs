{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "sequoia",
    "appearance": {
        "default": "dark",
        "strict": true
    },
    "name": "Astaria Docs",
    "colors": {
        "primary": "#FF972F",
        "light": "#FF972F",
        "dark": "#FF972F"
    },
    "fonts": {
        "heading": {
            "family": "Syne"
        },
        "body": {
            "family": "Montserrat"
        }
    },
    "favicon": "/favicon.png",
    "navigation": {
        "pages": [
            {
                "group": "Overview",
                "pages": ["/overview/about"]
            },
            {
                "group": "Trading",
                "pages": [
                    "/trading/order-types",
                    "/trading/price",
                    "/trading/account-value",
                    "/trading/margin",
                    "/trading/liquidations",
                    "/trading/socialized-losses",
                    "/trading/funding",
                    "/trading/tp-sl",
                    "/trading/self-trade",
                    "/trading/fees",
                    "/trading/margin-tiers",
                    "/trading/settlement",
                    "/trading/market-eligibility"
                ]
            }
        ]
    },
    "logo": {
        "light": "/logo/light.svg",
        "dark": "/logo/dark.svg"
    },
    "navbar": {
        "links": [
            {
                "label": "Home",
                "href": "https://astaria.trade"
            }
        ]
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude"
        ]
    },
    "footer": {
        "socials": {
            "x": "https://x.com/AstariaTrade"
        }
    }
}
